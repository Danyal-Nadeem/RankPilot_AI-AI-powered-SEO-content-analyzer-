{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_API_URL": {
      "description": "Your deployed backend URL (e.g. https://rankpilot-backend.up.railway.app)",
      "required": true
    }
  }
}
