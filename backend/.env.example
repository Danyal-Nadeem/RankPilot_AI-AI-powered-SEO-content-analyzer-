# Application Configuration
APP_NAME="RankPilot AI"
APP_ENV=development
DEBUG=true
PORT=8000
HOST=0.0.0.0

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# MongoDB Atlas Connection
# Replace with your MongoDB Atlas Cluster SRV Connection string
MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=rankpilot

# Upstash Redis Connection
# Copy the TLS/SSL connection string (rediss:// protocol) from your Upstash console
REDIS_URL=rediss://default:<password>@<endpoint>.upstash.io:<port>

# JWT Configuration
JWT_SECRET_KEY=supersecretaccesskeyfordev
JWT_REFRESH_SECRET_KEY=supersecretrefreshkeyfordev

# Anthropic / Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxx

# Email Configuration (choose one method)
# Option A: Resend API (recommended — free 3000 emails/month)
RESEND_API_KEY=re_xxxxxx
SMTP_FROM=noreply@rankpilot.ai

# Option B: Standard SMTP (fallback)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@rankpilot.ai
